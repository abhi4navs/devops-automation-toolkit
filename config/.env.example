# config/.env.production
# Copy to .env.production and fill in your values.
# This file should be in .gitignore — never commit credentials.

APP_NAME=myapp
APP_DIR=/var/www/myapp
GIT_REPO=https://github.com/yourusername/myapp.git
GIT_BRANCH=main
SERVICE_NAME=myapp
DEPLOY_USER=www-data
RELEASES_DIR=/var/www/releases/myapp
HEALTH_CHECK_URL=http://localhost:8080/health

# Database
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=dbuser
DB_PASS=changeme
DB_NAMES=myapp_prod

# Backup destination
BACKUP_DEST=/var/backups/myapp
